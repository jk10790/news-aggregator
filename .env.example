# Active LLM Provider Selection: "gemini" or "ollama"
LLM_PROVIDER=gemini

# Gemini API Configurations
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RATE_DELAY=13.0

# -----------------------------------------------------------------------------
# Messaging Provider Setup (twilio or telegram)
# -----------------------------------------------------------------------------
MESSAGING_PROVIDER=twilio

# Twilio Settings (If using Twilio)
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_SENDER=whatsapp:+14155238886

# Telegram Settings (If using Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Ollama Local Configurations
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_RATE_DELAY=0.0

# Groq API Configurations (Optional)
GROQ_API_KEY=your_groq_api_key_here
GROQ_RATE_DELAY=1.0

# Infrastructure Endpoints
REDPANDA_BROKER=localhost:9092
# ChromaDB Configuration
CHROMA_SERVER_HOST=localhost
CHROMA_SERVER_PORT=8002
CHROMA_RETENTION_DAYS=7
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/news_aggregator

# Application Configurations
INGESTION_INTERVAL_SECONDS=300
DAILY_BRIEF_CRON="0 6 * * *"
